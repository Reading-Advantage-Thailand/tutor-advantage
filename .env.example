# ============================================================
# Tutor Advantage — Root Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string (Cloud SQL via cloud-sql-proxy or direct)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/tutor_advantage

# Secondary DB (Reading Advantage content service — optional)
DATABASE_URL_READING_ADVANTAGE=postgresql://USER:PASSWORD@localhost:5432/reading_advantage

# Primary Advantage content database (required to run Primary articles)
DATABASE_URL_PRIMARY_ADVANTAGE=postgresql://USER:PASSWORD@localhost:5432/primary_advantage

# ── Auth / JWT ────────────────────────────────────────────
# Must be a long random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64

# ── OAuth Providers ───────────────────────────────────────
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

AUTH_FACEBOOK_ID=your-facebook-app-id
AUTH_FACEBOOK_SECRET=your-facebook-app-secret

# Redirect URI registered in Google / Facebook OAuth app
OAUTH_REDIRECT_URI=http://localhost:3001/v1/auth/callback

# ── LINE Integration ──────────────────────────────────────
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# LIFF App ID (from LINE Developers Console)
NEXT_PUBLIC_LIFF_ID=your-liff-app-id

# LIFF public URL (used for push notification deep-links)
LIFF_URL=https://liff.line.me/YOUR_LIFF_ID

# ── Payment — Omise ───────────────────────────────────────
OMISE_PUBLIC_KEY=pkey_test_...
OMISE_PRIVATE_KEY=skey_test_...
OMISE_WEBHOOK_SECRET=your-omise-webhook-secret
OMISE_API_BASE_URL=https://api.omise.co

# ── Google Cloud Storage ──────────────────────────────────
GCS_BUCKET_NAME=your-gcs-bucket-name
GCP_PROJECT_ID=your-gcp-project-id
# Path to service account JSON key file (local dev only)
# In production use Workload Identity instead
GCP_KEY_FILEPATH=./service-account.json
# Or set the full JSON as an env var (takes priority over GCP_KEY_FILEPATH)
# GOOGLE_APPLICATION_CREDENTIALS={"type":"service_account",...}

# ── Settlement Scheduler ──────────────────────────────────
# Shared secret for POST /v1/internal/settlement/auto-run
# Must match the value in Cloud Scheduler job config
INTERNAL_API_KEY=change-me-to-a-long-random-secret

# ── MLM Commission ────────────────────────────────────────
# Base commission rate (0–1). Default: 0.5 (50%)
COMMISSION_BASE_RATE=0.5

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://student-liff-1090865515742.asia-southeast1.run.app,https://resource-pushpin-tabby.ngrok-free.dev,http://localhost:3004,http://localhost:3005,http://localhost:3006

# ── Frontend URLs ─────────────────────────────────────────
FRONTEND_APP_URL=https://student-liff-1090865515742.asia-southeast1.run.app
STUDENT_APP_BASE_URL=https://student-liff-1090865515742.asia-southeast1.run.app
TUTOR_APP_BASE_URL=http://localhost:3005
NEXT_PUBLIC_BASE_URL=http://localhost:3005

# ── Service Ports ─────────────────────────────────────────
# identity-service
# PORT=3001
# learning-service
# PORT=3002
# finance-mlm-service
# PORT=3003

# ── Tax Documents (ใบ 50 ทวิ) ────────────────────────────
# Company info printed on the withholding tax certificate
TAWI50_COMPANY_NAME=บริษัท รีดิ้งแอดแวนเทจ(ไทยแลนด์) จำกัด
TAWI50_COMPANY_TAX_ID=0405567001165
TAWI50_COMPANY_ADDRESS=322/132 หมู่ที่ 20 ตำบลบ้านเป็ด อำเภอเมืองขอนแก่น จ.ขอนแก่น 40000
TAWI50_SIGNATORY_NAME=พิกุล ภูกะฐิน
